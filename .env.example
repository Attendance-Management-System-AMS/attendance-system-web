# --- Client (axios) — biến có prefix VITE_ ---
# Dev: thường `/api` để đi qua proxy Vite. Production build: URL backend đầy đủ nếu cần.
VITE_API_URL=/api

# --- Chỉ đọc trong vite.config (KHÔNG gửi vào bundle JS) ---
# Target cho proxy `/api` khi `npm run dev` (mặc định http://localhost:9000).
# DEV_PROXY_TARGET=http://127.0.0.1:9000

# Host được phép gọi dev server (cách nhau dấu phẩy). Để trống = mọi host.
# DEV_ALLOWED_HOSTS=myapp.ngrok-free.dev
